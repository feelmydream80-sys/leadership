{
  "auto_mapping_version": "v1.0",
  "documentation": {
    "overview": "Micro Label(M/N)를 기반으로 Trait을 자동 매핑하기 위한 규칙 정의. 수동 rule 없이도 Trait 후보를 생성한다.",
    "core_logic": [
      "Micro Label의 macro category를 기반으로 Trait 후보군을 1차 필터링",
      "label_name semantic 키워드를 기반으로 Trait score 가중치 부여",
      "core label 여부에 따라 가중치 추가",
      "Negative Label은 penalty 또는 suppression으로 반영",
      "최종적으로 score 상위 Trait을 Primary/Secondary로 선정"
    ],
    "processing_steps": [
      "1. NLP → Micro Label 추출",
      "2. macro 기반 Trait 후보군 매핑",
      "3. keyword 기반 weight 추가",
      "4. core/critical 여부 반영",
      "5. score aggregation",
      "6. 상위 Trait 선정"
    ]
  },

