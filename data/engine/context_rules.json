          {"micro_code": "M19-01", "reason": "불완전 정보 결정이 Required로 격상"},
          {"micro_code": "M20-01", "reason": "위기 원인 파악이 Required로 격상"}
        ],
        "trait_multipliers": {
          "T11": 1.3,
          "T12": 1.3,
          "T20": 1.3,
          "T08": 1.3
        }
      },
      "normal": {
        "description": "일반 상황",
        "required_threshold_relaxation": "없음",
        "required_promotions": [],
        "trait_multipliers": {}
      },
      "innovation": {
        "description": "혁신 상황",
        "required_threshold_relaxation": "없음",
        "required_promotions": [
          {"micro_code": "M23-01", "weight_multiplier": 1.2, "reason": "혁신 탐색 가중치 증가"},
          {"micro_code": "M23-02", "weight_multiplier": 1.2, "reason": "소규모 실험 가중치 증가"}
        ],
        "optional_demotions": [
          {"micro_code": "M24-01", "reason": "프로세스 표준화가 Optional로 격하"}
        ],
        "trait_multipliers": {
          "T14": 1.3,
          "T15": 1.3,
          "T18": 1.3,
          "T05": 1.3
        }
      }
    }
  },
  "back_end_context": {
    "description": "출력 직전 해석 보정",
    "rules": [
      {
        "condition": {"trait_id": "T23", "context": "crisis"},
        "original_name": "통제형 관리자",
        "adjusted_name": "문제 해결형 리더",
        "rationale": "위기 상황에서는 통제가 문제 해결로 해석될 수 있음"
      },
      {
        "condition": {"trait_id": "T04", "context": "crisis"},
        "original_name": "공감형 서번트 리더",
        "adjusted_name": "위기 안정화 리더",
        "rationale": "위기 상황에서 공감은 안정화로 재해석"
      },
      {
        "condition": {"trait_id": "T14", "context": "normal"},
        "original_name": "변화 주도 혁신가",
