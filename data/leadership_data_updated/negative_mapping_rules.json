{
  "schema_version": "2026-04-v2",
  "negative_mapping_version": "v1.1",
  "documentation": {
    "overview": "본 매핑은 Negative Label(Nxx)을 Trait 평가 엔진의 Hard/Soft Forbidden 및 Risk Amplifier로 연결하기 위한 규칙 정의이다.",
    "design_principles": [
      "Hard Forbidden은 해당 Trait을 즉시 무효화하거나 강한 감점을 적용한다.",
      "Soft Forbidden은 패널티 기반 점수 감소로 반영된다.",
      "Risk Amplifier는 특정 Risk Trait을 강화시키는 역할을 한다.",
      "Critical Negative Label은 조직 붕괴 수준 리스크로 간주한다."
    ],
    "hard_forbidden_definition": "해당 Label이 일정 threshold 이상 발생 시 Trait 제거 또는 강제 Risk Trait 전환",
    "soft_forbidden_definition": "label penalty 값을 기반으로 Trait strength 감소",
    "risk_amplifier_definition": "특정 Negative Label이 누적될 경우 Risk Trait의 strength를 증가시킴",
    "critical_labels": [
      {
        "label": "N08",
        "reason": "책임 전가는 조직 신뢰 붕괴 유발"
      },
      {
        "label": "N15",
        "reason": "심리적 안전 파괴는 팀 성과 직접 저해"
      },
      {
        "label": "N28",
        "reason": "투명성 위반은 윤리 리스크"
      },
      {
        "label": "N34",
        "reason": "데이터 조작은 시스템 신뢰 붕괴"
      }
    ]
  },
